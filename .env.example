# ============================================================
# azure-ai-redteam-eval — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to source control.
# ============================================================

# Azure Subscription & Resource Group
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_LOCATION=eastus2

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Azure AI Foundry (for evaluations)
AZURE_AI_FOUNDRY_PROJECT=
AZURE_AI_FOUNDRY_ENDPOINT=https://<your-project>.api.azureml.ms

# Application Insights (for Continuous Monitoring)
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=<key>;IngestionEndpoint=https://<region>.in.applicationinsights.azure.com/

# Local dev
LOG_LEVEL=INFO

# Continuous Evaluation — Thresholds (override defaults from thresholds.py)
# CE_THRESHOLD_GROUNDEDNESS=4.0
# CE_THRESHOLD_COHERENCE=4.0
# CE_THRESHOLD_RELEVANCE=4.0
# CE_THRESHOLD_FLUENCY=4.0
# CE_THRESHOLD_SAFETY=5.0

# Local dev
LOG_LEVEL=INFO
